{
  "name": "@sk-productions/agent-studio",
  "version": "0.1.5",
  "description": "Open-source web and desktop workspace for AI coding agents",
  "private": false,
  "license": "Apache-2.0",
  "author": {
    "name": "SK Productions, LLC"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sammykumar/Agent-Studio.git"
  },
  "bugs": {
    "url": "https://github.com/sammykumar/Agent-Studio/issues"
  },
  "homepage": "https://github.com/sammykumar/Agent-Studio",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "coding-agent",
    "claude-code",
    "codex",
    "electron",
    "nextjs",
    "websocket"
  ],
  "main": "dist-server/server.js",
  "bin": {
    "agent-studio": "bin/agent-studio.mjs"
  },
  "files": [
    "bin/",
    "dist-server/",
    "!dist-server/**/*.map",
    ".next/",
    "!.next/cache/",
    "!.next/cache/**",
    "!.next/trace",
    "!.next/trace-build",
    "!.next/turbopack",
    "!.next/types/",
    "!.next/types/**",
    "!.next/**/*.map",
    "public/sounds/",
    "assets/",
    "docs/assets/readme/",
    "next.config.mjs",
    "README*.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "d3k --port 5001 --script dev:local --startup-timeout 90 --headless --no-agent --no-tui",
    "dev:local": "cross-env NODE_ENV=development AGENT_STUDIO_HOST=0.0.0.0 tsx server.ts",
    "dev:d3k": "d3k --port 5001 --startup-timeout 90 --headless --with-agent claude",
    "build": "cross-env TURBOPACK= __NEXT_DEV_SERVER= __NEXT_PROCESSED_ENV= NODE_ENV=production next build --webpack",
    "build:telemetry": "node scripts/with-posthog-telemetry-build.mjs npm run build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "eslint .",
    "server:compile": "node -e \"require('fs').rmSync('dist-server',{recursive:true,force:true})\" && tsc -p tsconfig.server.json",
    "electron:compile": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p electron/tsconfig.json",
    "electron:prepare-runtime": "node scripts/prepare-electron-runtime.mjs",
    "electron:dev": "npm run electron:compile && concurrently -k -n SERVER,ELECTRON -c cyan,yellow \"cross-env NODE_ENV=development PORT=5001 AGENT_STUDIO_ELECTRON_AUTH_BYPASS=1 npx tsx server.ts\" \"wait-on http://localhost:5001 && cross-env AGENT_STUDIO_DEV_PORT=5001 electron dist-electron/electron/main.js\"",
    "electron:prebuild": "npm run build && npm run electron:compile && npm run electron:prepare-runtime",
    "electron:prebuild:telemetry": "node scripts/with-posthog-telemetry-build.mjs npm run electron:prebuild",
    "electron:build:win": "npm run electron:prebuild && electron-builder --win portable --x64 --publish never",
    "electron:build:win:telemetry": "node scripts/with-posthog-telemetry-build.mjs npm run electron:build:win",
    "electron:build:linux": "npm run electron:prebuild && electron-builder --linux AppImage deb --x64 --publish never",
    "electron:build:mac-x64": "npm run electron:prebuild && electron-builder --mac --x64 --publish never",
    "electron:build:mac-arm64": "npm run electron:prebuild && electron-builder --mac --arm64 --publish never",
    "electron:build:mac-x64:signed": "npm run electron:prebuild && AGENT_STUDIO_MAC_DISTRIBUTION=1 electron-builder --mac dmg --x64 --publish never --config.forceCodeSigning=true --config.mac.notarize=false && node scripts/notarize-mac-dmg.cjs x64",
    "electron:build:mac-arm64:signed": "npm run electron:prebuild && AGENT_STUDIO_MAC_DISTRIBUTION=1 electron-builder --mac dmg --arm64 --publish never --config.forceCodeSigning=true --config.mac.notarize=false && node scripts/notarize-mac-dmg.cjs arm64",
    "electron:build:mac:signed": "npm run electron:prebuild && AGENT_STUDIO_MAC_DISTRIBUTION=1 electron-builder --mac dmg --x64 --arm64 --publish never --config.forceCodeSigning=true --config.mac.notarize=false && node scripts/notarize-mac-dmg.cjs x64 arm64",
    "electron:build:all": "npm run electron:prebuild && electron-builder build --publish never",
    "npm:prepack": "npm run build && npm run server:compile",
    "prepack": "npm run npm:prepack",
    "postinstall": "node -e \"const fs=require('fs'); if (fs.existsSync('.electron-runtime')) require('child_process').execFileSync('electron-builder', ['install-app-deps'], {stdio:'inherit'});\""
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "agentation": "^3.0.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.0",
    "i18next": "^25.8.13",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.563.0",
    "next": "^16.2.3",
    "node-pty": "^1.1.0",
    "pino": "^8.18.0",
    "posthog-js": "^1.372.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.4.0",
    "tinykeys": "^3.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.16.0",
    "zod": "^3.22.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/osx-sign": "^1.3.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "20.19.35",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "@vercel/nft": "^1.5.0",
    "autoprefixer": "^10.4.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.3",
    "pino-pretty": "^10.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.7.0",
    "typescript": "5.9.3",
    "wait-on": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "build": {
    "appId": "app.agentstudio.desktop",
    "productName": "Agent Studio",
    "copyright": "Copyright (c) 2026 SK Productions, LLC",
    "afterPack": "scripts/electron-after-pack.cjs",
    "npmRebuild": false,
    "asar": true,
    "asarUnpack": [
      "**/sql.js/**",
      "**/node_modules/sql.js/**",
      "**/node_modules/node-pty/prebuilds/**",
      "**/node_modules/node-pty/build/Release/*.node",
      "**/node_modules/node-pty/build/Debug/*.node"
    ],
    "files": [
      "**/*",
      "!**/.next/cache{,/**/*}",
      "!**/node_modules/electron{,/**/*}",
      "!**/node_modules/typescript{,/**/*}",
      "!**/node_modules/sharp{,/**/*}",
      "!**/node_modules/@img{,/**/*}"
    ],
    "directories": {
      "app": ".electron-runtime",
      "output": "release",
      "buildResources": "assets"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development",
      "icon": "assets/icon.png",
      "maintainer": "SK Productions, LLC <sam@skproductions.llc>",
      "executableName": "agent-studio"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "scripts/entitlements.mac.plist",
      "entitlementsInherit": "scripts/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "Agent-Studio-${version}-macos-${arch}.${ext}",
      "sign": true
    },
    "portable": {
      "artifactName": "Agent-Studio-${version}-windows-${arch}.${ext}"
    },
    "deb": {
      "packageName": "agent-studio",
      "artifactName": "Agent-Studio-${version}-linux-${arch}.${ext}"
    }
  }
}
